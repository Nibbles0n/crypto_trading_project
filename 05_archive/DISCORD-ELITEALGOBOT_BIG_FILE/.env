# ============ Discord Configuration ============
# Your Discord user token (required for the bot to connect to Discord)
DISCORD_USER_TOKEN=your_token_here

# Channel IDs to monitor for trading signals (comma-separated)
DISCORD_CHANNEL_IDS=your_id_here

# ============ Kraken API Configuration ============
# API credentials from Kraken (required for live trading)
KRAKEN_API_KEY=your_api_key_here
KRAKEN_SECRET=your_api_secret_here

# ============ Trading Parameters ============
# Risk management (1.0 = 1% of account balance per trade)
RISK_PERCENT=your_risk_percent

# Maximum number of concurrent open positions
MAX_TRADES=your_max_trades

# Leverage (1 = no leverage, 2 = 2x, etc.)
LEVERAGE=your_leverage

# Default quote currency for position sizing (e.g., USDT, USD)
QUOTE_CURRENCY=your_quote_currency

# ============ Order Settings ============
# Enable/disable paper trading mode (true/false)
PAPER_TRADING=your_paper_trading

# Slippage tolerance in percentage (0.5 = 0.5%)
SLIPPAGE_TOLERANCE=your_slippage_tolerance

# ============ Logging & Monitoring ============
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=your_log_level

# Path to store trade logs (relative to script location)
LOG_DIR=your_log_dir

# ============ Advanced Settings ============
# Enable/disable dry run mode (no real trades will be executed)
DRY_RUN=your_dry_run

# Auto-cancel open orders after X hours (0 to disable)
ORDER_TIMEOUT_HOURS=your_order_timeout_hours

# Maximum position size as percentage of 24h volume (0-100)
MAX_VOLUME_PERCENT=your_max_volume_percent
