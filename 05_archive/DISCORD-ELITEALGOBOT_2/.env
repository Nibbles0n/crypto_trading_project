# Discord User Account Configuration
DISCORD_USER_TOKEN=your_token_here

# Add channel IDs separated by commas (e.g., 1234567890,9876543210)
DISCORD_CHANNEL_IDS=your_id_here

# Kraken API Configuration
KRAKEN_API_KEY=your_api_key_here
KRAKEN_SECRET=your_api_secret_here

# Optional: Trading Settings
# TRADE_AMOUNT=0.01  # Default trade size in BTC
# MAX_TRADES=5       # Maximum number of concurrent trades
# LEVERAGE=1         # Leverage to use (1 for no leverage)