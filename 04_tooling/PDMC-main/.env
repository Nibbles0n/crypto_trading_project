# RPC Configuration
HELIUS_API_KEY=your_api_key_here
HELIUS_RPC_URL=your_helius_rpc_url
HELIUS_WS_URL=your_helius_ws_url

# Wallet Configuration
PRIVATE_KEY=your_api_key_here

# Trading Parameters
BUY_AMOUNT_SOL=your_buy_amount_sol
# Amount of SOL to spend per trade
TAKE_PROFIT_PERCENT=your_take_profit_percent
# Take profit at 5% gain
STOP_LOSS_PERCENT=your_stop_loss_percent
# Stop loss at 2% loss
TRAILING_STOP_PERCENT=your_trailing_stop_percent
# Trailing stop trigger
SLIPPAGE_BUY=your_slippage_buy
# Buy slippage tolerance (%)
SLIPPAGE_SELL=your_slippage_sell
# Sell slippage tolerance (%)

# Risk Management
MAX_CONCURRENT_POSITIONS=your_max_concurrent_positions
# Maximum open positions
MIN_LIQUIDITY_USD=your_id_here
# Minimum pool liquidity (0 = no limit)
MAX_POSITION_SIZE_SOL=your_max_position_size_sol
 Maximum position size
RUG_PULL_THRESHOLD_USD=your_rug_pull_threshold_usd
 Sell detection threshold

# MEV Protection
USE_MEV_PROTECTION=your_use_mev_protection
# Enable Jito MEV protection
JITO_TIP_LAMPORTS=your_jito_tip_lamports
Jito tip amount (0.00001 SOL)