# =============================================================================
# BANANAS TRADING BOT - Configuration Template
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# EXCHANGE APIS
# =============================================================================
# Kraken API (leave empty for simulation mode)
# Get keys from: https://www.kraken.com/u/security/api
# Required permissions: Query Funds, Query Open Orders & Trades, Create & Modify Orders
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# =============================================================================
# TELEGRAM NOTIFICATIONS
# =============================================================================
# 1. Create bot with @BotFather on Telegram
# 2. Get chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# TRADING CONFIG
# =============================================================================
MAX_HOLDINGS=5
TOTAL_CAPITAL=10000
# Tokens to trade (from backtest validation)
TRADING_TOKENS=JUP,RAD,AUDIO,WIF,BONK,PEPE,HOOK,DOGE

# =============================================================================
# RANGE FILTER 1 - Optimized Settings (DO NOT CHANGE)
# =============================================================================
RF1_RANGE_SCALE=Normalized Average Change
RF1_RANGE_SIZE=1.1
RF1_RANGE_PERIOD=19
RF1_FILTER_TYPE=Type 1
RF1_MOVEMENT_SOURCE=Wicks
RF1_SMOOTH_RANGE=true
RF1_SMOOTHING_PERIOD=95
RF1_AVG_FILTER_CHANGES=true
RF1_CHANGES_TO_AVG=2

# =============================================================================
# RANGE FILTER 2 - Optimized Settings (DO NOT CHANGE)
# =============================================================================
RF2_RANGE_SCALE=Normalized Average Change
RF2_RANGE_SIZE=6.2
RF2_RANGE_PERIOD=24
RF2_FILTER_TYPE=Type 1
RF2_MOVEMENT_SOURCE=Wicks
RF2_SMOOTH_RANGE=true
RF2_SMOOTHING_PERIOD=60
RF2_AVG_FILTER_CHANGES=false
RF2_CHANGES_TO_AVG=2

# =============================================================================
# SIGNAL FILTERS - Optimized Settings (DO NOT CHANGE)
# =============================================================================
EXIT_MODE=Signal Only
ENABLE_PROFIT_POTENTIAL=true
MIN_PROFIT_POTENTIAL=1.4
ENABLE_QUALITY_FILTER=true
MIN_QUALITY_SCORE=0
QUALITY_LOOKBACK=21
MIN_SIGNAL_RATING=1
SHOW_ALL_SIGNALS=false
USE_COOLDOWN=false
COOLDOWN_BARS=0
ENABLE_PRICE_DISTANCE_FILTER=true
MIN_PRICE_DISTANCE_PCT=0.5
USE_ALTERNATE_SIGNALS=false
ENABLE_SIGNAL_SIZING=true

# =============================================================================
# EXIT SETTINGS - Signal Only Mode (DO NOT CHANGE)
# =============================================================================
MAX_PROFIT_CAP=100.0
USE_PROFIT_CAP=false
MAX_LOSS_CAP=100.0
USE_LOSS_CAP=false
PEAK_PROFIT_TRIGGER=100.0
PEAK_DRAWDOWN_PCT_INPUT=100.0
PEAK_LOOKBACK_BARS=2
MIN_PROFIT_THRESHOLD=0.0
ENABLE_SAME_DIRECTION_AUTOCLOSE=false
USE_REGIME_ADAPTIVE_EXITS=false

# =============================================================================
# REGIME SETTINGS (disabled)
# =============================================================================
ADX_PERIOD=14
RANGING_MAX_PROFIT=100.0
RANGING_PEAK_DD=100.0
EXPLOSIVE_MIN_PROFIT=100.0
EXPLOSIVE_PEAK_DD=100.0

# =============================================================================
# WEB DASHBOARD
# =============================================================================
# Generate hash: node -e "require('bcrypt').hash('YOUR_PASSWORD', 10, (e,h) => console.log(h))"
WEB_PASSWORD_HASH=
SESSION_SECRET=change-this-to-a-random-string-for-production
WEB_PORT=3001
BOT_API_PORT=5001
BOT_API_URL=http://localhost:5001
